# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Keyword backend (default: mock — no key needed for dry runs) ─────────────
# Options: mock | serpapi | dataforseo
KEYWORD_BACKEND=mock

# SerpAPI (optional — set KEYWORD_BACKEND=serpapi to use)
SERPAPI_KEY=

# DataForSEO (optional — set KEYWORD_BACKEND=dataforseo to use)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── AEO Monitor ─────────────────────────────────────────────────────────────
# Optional: also monitors ChatGPT responses
OPENAI_API_KEY=

# ── Google Search Console (optional — ranking agent falls back to mock data) ─
GSC_SITE_URL=https://your-site.com
GSC_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ── Notifications (optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
